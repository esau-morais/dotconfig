{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"bun": {
			"enabled": true,
			"type": "remote",
			"url": "https://bun.com/docs/mcp"
		},
		"remotion": {
			"type": "local",
			"enabled": false,
			"command": ["npx", "-y", "@remotion/mcp@latest"]
		},
		"shadcn": {
			"type": "local",
			"command": ["npx", "shadcn@latest", "mcp"],
			"enabled": true
		},
		"astro": {
			"type": "remote",
			"url": "https://mcp.docs.astro.build/mcp",
			"enabled": false
		}
	}
}
